{
  "name": "00o-platform",
  "version": "1.0.0",
  "private": true,
  "description": "00o.uz — O'zbek tilidagi eng katta onlayn platforma",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @00o/web dev",
    "dev:api": "pnpm --filter @00o/api dev",
    "dev:bot": "pnpm --filter @00o/bot dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @00o/web build",
    "build:api": "pnpm --filter @00o/api build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "clean": "pnpm -r exec rm -rf dist .next node_modules .turbo"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "@types/node": "^26.1.1",
    "prettier": "^3.3.3",
    "eslint": "^10.7.0"
  }
}
