{
  "name": "@00o/api",
  "version": "1.0.0",
  "private": true,
  "description": "00o.uz backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@00o/database": "workspace:*",
    "@00o/utils": "workspace:*",
    "@00o/types": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "zod": "^4.4.3",
    "ioredis": "^5.4.1",
    "dayjs": "^1.11.13",
    "nanoid": "^6.0.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/speakeasy": "^2.0.10",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "vitest": "^2.1.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
