# ========================================
# 00o.uz API — Environment Variables
# ========================================

# Server
NODE_ENV=production
PORT_API=4000
API_URL=https://api.00o.uz
FRONTEND_URL=https://00o.uz
CORS_ORIGINS=https://00o.uz,https://www.00o.uz,http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/00o_production

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-this-to-super-secret-32-chars-min
JWT_REFRESH_SECRET=change-this-to-different-super-secret-32-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256

# AI (Groq Cloud)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=ooouzbot
TELEGRAM_WEBHOOK_URL=https://api.00o.uz/api/v1/bot/webhook

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Sentry (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=info
