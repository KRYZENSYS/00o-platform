# Application
APP_NAME=00o.uz
APP_ENV=development
APP_DEBUG=True
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=change-this-super-secret-key-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ooouzb

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AI - GroqCloud
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1
AI_DEFAULT_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_MODEL=llama-3.1-8b-instant
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=oouzb_bot
TELEGRAM_WEBHOOK_URL=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Payments
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@00o.uz

# CORS
CORS_ORIGINS=["http://localhost:3000","https://00o.uz","https://app.00o.uz"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
