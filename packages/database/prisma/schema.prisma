// 00o.uz - Production Database Schema
// PostgreSQL + Prisma ORM
// 30+ tables covering all platform features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== AUTH & USERS ==============

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  username      String    @unique
  password      String?
  displayName   String?
  avatar        String?
  bio           String?   @db.Text
  role          Role      @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  twoFAEnabled  Boolean   @default(false)
  twoFASecret   String?
  language      String    @default("uz")
  timezone      String    @default("Asia/Tashkent")
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile           Profile?
  sessions          Session[]
  refreshTokens     RefreshToken[]
  todos             Todo[]
  notes             Note[]
  passwords         PasswordEntry[]
  habits            Habit[]
  habitLogs         HabitLog[]
  bookmarks         Bookmark[]
  events            CalendarEvent[]
  transactions      Transaction[]
  budgets           Budget[]
  workoutLogs       WorkoutLog[]
  waterLogs         WaterLog[]
  sleepLogs         SleepLog[]
  moodLogs          MoodLog[]
  meditationLogs    MeditationLog[]
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  follows           Follow[]      @relation("Follower")
  followers         Follow[]      @relation("Following")
  stories           Story[]
  storyViews        StoryView[]
  sentMessages      Message[]     @relation("MessageSender")
  receivedMessages  Message[]     @relation("MessageReceiver")
  conversations1    Conversation[] @relation("ConvUser1")
  conversations2    Conversation[] @relation("ConvUser2")
  notifications     Notification[] @relation("NotifUser")
  triggeredNotifs   Notification[] @relation("NotifActor")
  uploads           Media[]
  achievements      UserAchievement[]
  xp                XpLog[]
  subscription      Subscription?
  payments          Payment[]
  invoices          Invoice[]
  apiKeys           ApiKey[]
  reports           Report[]      @relation("ReportReporter")
  reportedBy        Report[]      @relation("ReportReported")
  blocks            Block[]       @relation("BlockBlocker")
  blockedBy         Block[]       @relation("BlockBlocked")
  devices           Device[]
  pushSubscriptions PushSubscription[]
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]
  phoneVerifications PhoneVerification[]
  loginAttempts     LoginAttempt[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([username])
  @@index([createdAt])
  @@map("users")
}

enum Role {
  USER
  PREMIUM
  BUSINESS
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
  PENDING
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  birthDate   DateTime?
  gender      Gender?
  country     String   @default("UZ")
  city        String?
  address     String?
  website     String?
  socialLinks Json?
  preferences Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  ip           String
  userAgent    String   @db.Text
  device       String?
  os           String?
  browser      String?
  country      String?
  city         String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  ip        String
  userAgent String?  @db.Text
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([ip])
  @@index([createdAt])
  @@map("login_attempts")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ip        String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_resets")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  email     String
  token     String    @unique
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verifications")
}

model PhoneVerification {
  id        String    @id @default(cuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  verifiedAt DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@map("phone_verifications")
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String   @unique
  name       String?
  type       DeviceType
  os         String?
  osVersion  String?
  app        String?
  appVersion String?
  fcmToken   String?
  trusted    Boolean  @default(false)
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  BOT
  OTHER
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ============== PRODUCTIVITY ==============

model Todo {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  priority    Priority   @default(MEDIUM)
  status      TodoStatus @default(PENDING)
  category    String?
  tags        String[]
  dueDate     DateTime?
  completedAt DateTime?
  parentId    String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Todo? @relation("SubTodos", fields: [parentId], references: [id])
  subs   Todo[] @relation("SubTodos")

  @@index([userId, status])
  @@index([userId, dueDate])
  @@map("todos")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ARCHIVED
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  category  String?
  tags      String[]
  color     String   @default("#8b5cf6")
  isPinned  Boolean  @default(false)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isArchived])
  @@map("notes")
}

model PasswordEntry {
  id          String   @id @default(cuid())
  userId      String
  title       String
  username    String?
  email       String?
  password    String   @db.Text
  url         String?
  category    String?
  notes       String?  @db.Text
  isFavorite  Boolean  @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_entries")
}

model Habit {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?    @db.Text
  icon        String     @default("✅")
  color       String     @default("#8b5cf6")
  frequency   Frequency  @default(DAILY)
  targetDays  Int[]      @default([1, 2, 3, 4, 5, 6, 7])
  targetCount Int        @default(1)
  unit        String?
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime @db.Date
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_logs")
}

model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  url         String
  title       String
  description String?  @db.Text
  favicon     String?
  image       String?
  category    String?
  tags        String[]
  isFavorite  Boolean  @default(false)
  clicks      Int      @default(0)
  lastClicked DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bookmarks")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?   @db.Text
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String    @default("#8b5cf6")
  category    String?
  reminder    Int?
  recurrence  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@map("calendar_events")
}

// ============== FINANCE ==============

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal           @db.Decimal(18, 2)
  currency    String            @default("UZS")
  category    String
  description String?           @db.Text
  date        DateTime
  paymentMethod String?
  tags        String[]
  attachment  String?
  recurring   Boolean           @default(false)
  recurringPeriod RecurringPeriod?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
  SAVING
}

enum RecurringPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  name      String
  category  String?
  amount    Decimal  @db.Decimal(18, 2)
  currency  String   @default("UZS")
  period    BudgetPeriod @default(MONTHLY)
  startDate DateTime
  endDate   DateTime?
  spent     Decimal  @default(0) @db.Decimal(18, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("budgets")
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

// ============== HEALTH ==============

model WorkoutLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  duration  Int
  calories  Int?
  intensity Intensity @default(MEDIUM)
  notes     String?  @db.Text
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("workout_logs")
}

enum Intensity {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  date      DateTime @db.Date
  time      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("water_logs")
}

model SleepLog {
  id          String   @id @default(cuid())
  userId      String
  sleepTime   DateTime
  wakeTime    DateTime
  duration    Int
  quality     SleepQuality @default(GOOD)
  notes       String?  @db.Text
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("sleep_logs")
}

enum SleepQuality {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  mood      Mood     @default(NEUTRAL)
  energy    Int      @default(5)
  stress    Int      @default(5)
  notes     String?  @db.Text
  activities String[]
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("mood_logs")
}

enum Mood {
  AWFUL
  BAD
  NEUTRAL
  GOOD
  AMAZING
}

model MeditationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  duration  Int
  guide     String?
  notes     String?  @db.Text
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("meditation_logs")
}

// ============== SOCIAL ==============

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  type      PostType @default(TEXT)
  visibility Visibility @default(PUBLIC)
  mediaIds  String[]
  tags      String[]
  mentions  String[]
  location   String?
  isPinned  Boolean  @default(false)
  isEdited  Boolean  @default(false)
  likesCount Int     @default(0)
  commentsCount Int  @default(0)
  sharesCount Int    @default(0)
  viewsCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("posts")
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
  QUESTION
  ACHIEVEMENT
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
  FRIENDS
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  parentId  String?
  likesCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")

  @@index([postId, createdAt])
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      LikeType @default(LIKE)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@map("likes")
}

enum LikeType {
  LIKE
  LOVE
  LAUGH
  WOW
  SAD
  ANGRY
  FIRE
  CLAP
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  isAccepted  Boolean  @default(true)
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Story {
  id          String   @id @default(cuid())
  userId      String
  mediaId     String?
  content     String?  @db.Text
  type        StoryType @default(IMAGE)
  visibility  Visibility @default(PUBLIC)
  viewsCount  Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("stories")
}

enum StoryType {
  IMAGE
  VIDEO
  TEXT
  POLL
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  viewedAt  DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_views")
}

model Conversation {
  id         String   @id @default(cuid())
  user1Id    String
  user2Id    String
  lastMessageAt DateTime?
  unreadCount1 Int    @default(0)
  unreadCount2 Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user1    User      @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  content        String   @db.Text
  type           MessageType @default(TEXT)
  mediaId        String?
  isRead         Boolean  @default(false)
  readAt         DateTime?
  isEdited       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, receiverId])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  LOCATION
  CONTACT
  STICKER
  GIF
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  actorId   String?
  type      NotifType
  title     String
  body      String?  @db.Text
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User  @relation("NotifUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum NotifType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
  MESSAGE
  SYSTEM
  PROMO
  ACHIEVEMENT
  REMINDER
  PAYMENT
  SECURITY
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  type        ReportType
  reason      String
  description String?  @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  reporter User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportReported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("reports")
}

enum ReportType {
  USER
  POST
  COMMENT
  MESSAGE
  PROFILE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

// ============== MEDIA ==============

model Media {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String   @db.Text
  thumbnail   String?  @db.Text
  width       Int?
  height      Int?
  duration    Int?
  isPublic    Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mimeType])
  @@map("media")
}

// ============== GAMIFICATION ==============

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String   @db.Text
  icon        String
  category    String
  points      Int      @default(10)
  rarity      Rarity   @default(COMMON)
  criteria    Json
  createdAt   DateTime @default(now())

  users UserAchievement[]

  @@map("achievements")
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  progress      Int      @default(0)
  unlockedAt    DateTime?
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  source    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_logs")
}

// ============== PAYMENTS ==============

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  plan            Plan
  status          SubStatus @default(ACTIVE)
  startDate       DateTime @default(now())
  endDate         DateTime?
  trialEndsAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  autoRenew       Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([status, endDate])
  @@map("subscriptions")
}

enum Plan {
  FREE
  PRO_MONTHLY
  PRO_YEARLY
  BUSINESS_MONTHLY
  BUSINESS_YEARLY
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  PAUSED
}

model Payment {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String?
  amount         Decimal  @db.Decimal(18, 2)
  currency       String   @default("UZS")
  provider       PayProvider
  providerId     String?
  status         PayStatus @default(PENDING)
  method         String?
  description    String?
  metadata       Json?
  paidAt         DateTime?
  refundedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([providerId])
  @@map("payments")
}

enum PayProvider {
  PAYME
  CLICK
  UZUM
  STRIPE
  CASH
  BANK_TRANSFER
}

enum PayStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Invoice {
  id          String   @id @default(cuid())
  userId      String
  number      String   @unique
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("UZS")
  tax         Decimal  @default(0) @db.Decimal(18, 2)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime @default(now())
  dueAt       DateTime?
  paidAt      DateTime?
  items       Json
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String   @unique
  secret      String
  scopes      String[]
  rateLimit   Int      @default(1000)
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@map("api_keys")
}

// ============== AUDIT ==============

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  ip        String?
  userAgent String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
