# =============================================
# 00o.uz - Environment Configuration
# =============================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ooouz
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/ooouz

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_chars_long_2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AI (GroqCloud - REQUIRED)
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Telegram Bot (REQUIRED for bot + telegram auth)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=ooouzbot

# WebApp
WEBAPP_URL=https://00o.uz
NEXT_PUBLIC_API_URL=https://00o.uz/api/v1
NEXT_PUBLIC_WS_URL=wss://00o.uz/ws
NEXT_PUBLIC_BOT_USERNAME=ooouzbot

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYME_SECRET_KEY=your_payme_key
PAYME_MERCHANT_ID=your_merchant_id
CLICK_SECRET_KEY=your_click_secret
CLICK_MERCHANT_ID=your_merchant_id

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@00o.uz
SMTP_PASSWORD=app_specific_password
SMTP_FROM=00o.uz <noreply@00o.uz>

# CORS
CORS_ORIGINS=https://00o.uz,https://www.00o.uz,https://app.00o.uz

# Environment
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# Ports
API_PORT=8000
WEB_PORT=3000

# Token economy
TOKEN_PRICE=1000
REFERRAL_BONUS=100
PREMIUM_REFERRAL_BONUS=500
