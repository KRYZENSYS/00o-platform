# 00o.uz — Root .env.example

# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/00o_db

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-to-64-char-random-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ===== AI (Groq) =====
GROQ_API_KEY=gsk_your_key_here

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# ===== Storage =====
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=00o-uploads
R2_PUBLIC_URL=https://cdn.00o.uz

# ===== Monitoring =====
SENTRY_DSN=

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,https://00o.uz
