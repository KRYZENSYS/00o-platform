# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oo_uz?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
BCRYPT_ROUNDS=12

# App
NODE_ENV="development"
PORT_API=4000
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
APP_NAME="00o.uz"

# Storage (R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="oo-uz-media"

# Email
RESEND_API_KEY=""
EMAIL_FROM="noreply@00o.uz"

# SMS
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""

# Payments
PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
PAYME_TEST=1
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
UZUM_MERCHANT_ID=""
UZUM_SECRET_KEY=""
STRIPE_SECRET_KEY=""

# Push
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Monitoring
SENTRY_DSN=""
POSTHOG_KEY=""

# Telegram
TELEGRAM_BOT_TOKEN=""

# Rate Limit
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
